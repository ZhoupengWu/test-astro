---
import { getCollection } from "astro:content";
import "../styles/global.css";

const articles = await getCollection("articles");
---

<!DOCTYPE html>
<html lang="it">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Il Mio Giornale - Ultimi Articoli</title>
    </head>
    <body class="bg-gray-100 text-black">
        <header class="p-4 bg-white shadow">
            <h1 class="text-4xl font-bold max-w-4xl mx-auto">Il Mio Giornale</h1>
        </header>

        <main class="max-w-4xl mx-auto p-4">
            <h2 class="text-2xl font-semibold mb-4">Ultimi articoli</h2>

            <div class="space-y-4">
                {
                    articles.map((article) => (
                        <article class="bg-white p-4 rounded shadow">
                            <h3 class="text-xl font-bold">
                                <a href={`/article/${article.id}`} class="text-blue-600 hover:underline">
                                    {article.data.title}
                                </a>
                            </h3>
                            <p class="text-gray-600 text-sm mb-2">{article.data.date.toLocaleDateString('it-IT')}</p>
                            <p>{article.data.description}</p>
                        </article>
                    ))
                }
            </div>
        </main>
    </body>
</html>
